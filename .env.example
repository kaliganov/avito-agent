# --- App ---
APP_ENV=development
# MySQL (основной вариант): создайте БД с utf8mb4, затем:
DATABASE_URL=mysql+aiomysql://USER:PASSWORD@127.0.0.1:3306/chatbot?charset=utf8mb4
# Локально без MySQL: sqlite+aiosqlite:///./data/chatbot.db

# --- Avito API (OAuth2 client credentials + Messenger) ---
# См. https://developers.avito.ru/
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=
# Публичный URL вебхука для скрипта register_avito_webhook.py (тот же, что в кабинете)
AVITO_PUBLIC_WEBHOOK_URL=
# AVITO_OAUTH_SCOPE=messenger
# Базовый URL API (если Авито меняет — поправьте здесь)
AVITO_API_BASE=https://api.avito.ru
# Секрет для проверки подписи вебхука (как в кабинете Avito для URL). Пусто = проверка отключена.
AVITO_WEBHOOK_SECRET=
# true = проверять подпись (если не сходится — вебхук получит 401). Для отладки оставьте false.
AVITO_WEBHOOK_VERIFY_SIGNATURE=false
# true = в лог пишется начало JSON вебхука (удобно подстроить разбор под формат Avito).
AVITO_WEBHOOK_LOG_PAYLOAD=true
# В ответе вебхука добавлять поле debug (смотреть в ngrok → запрос → Response). В проде — false.
AVITO_WEBHOOK_DEBUG_RESPONSE=true
# Свои numeric user id (через запятую), от сообщений которых не отвечать (например аккаунт продавца в чате)
AVITO_IGNORE_AUTHOR_IDS=
# Только для настройки: перечислите author_id (через запятую), кому отвечать; остальных игнорировать. Пусто = всем.
AVITO_ALLOW_ONLY_AUTHOR_IDS=
# User id продавца в Avito (цифры из профиля или из GET /core/v1/accounts/self). Нужен для отправки ответа в чат.
AVITO_ACCOUNT_USER_ID=
# Макс. длина одного ответа в чат (символы)
CHATBOT_REPLY_MAX_CHARS=1200

# --- LLM (бесплатно локально: Ollama) ---
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b

# Альтернатива: openai-compatible endpoint (Groq, OpenRouter и т.д.)
# LLM_PROVIDER=openai_compatible
# OPENAI_COMPAT_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_COMPAT_API_KEY=
# OPENAI_COMPAT_MODEL=llama-3.1-8b-instant

# --- amoCRM (OAuth2 long-lived token в проде храните безопасно) ---
AMOCRM_BASE_URL=https://YOUR_SUBDOMAIN.amocrm.ru
AMOCRM_ACCESS_TOKEN=
